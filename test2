-- ================= FUNÇÕES DO HUB =================
local function optimizeGame(mode)
	pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
	Lighting.GlobalShadows = false
	
	local count = 0
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") then
			obj.Material = Enum.Material.SmoothPlastic
			obj.CastShadow = false
		end
		if mode == "Competitive" then
			if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
				obj.Enabled = false
			elseif obj:IsA("Decal") or obj:IsA("Texture") then
				obj:Destroy()
			end
		end
		count += 1
		if count % 150 == 0 then task.wait() end
	end
end

local function BlackSky()
	for _, v in pairs(Lighting:GetChildren()) do
		if v:IsA("Sky") then v:Destroy() end
	end
	local sky = Instance.new("Sky")
	sky.Parent = Lighting
	Lighting.Ambient = Color3.new(0, 0, 0)
	Lighting.OutdoorAmbient = Color3.new(0, 0, 0)
end

-- ================= LÓGICA DE INTERFACE =================
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function toggleHub(state)
	if state then
		blur.Enabled = true
		hub.Visible = true
		openButton.Visible = false
		TweenService:Create(hub, tweenInfo, {Size = UDim2.new(0, 550, 0, 350)}):Play()
	else
		blur.Enabled = false
		local tween = TweenService:Create(hub, tweenInfo, {Size = UDim2.new(0, 0, 0, 0)})
		tween:Play()
		tween.Completed:Connect(function()
			if not blur.Enabled then
				hub.Visible = false
				openButton.Visible = true
			end
		end)
	end
end

local function addHover(btn)
	local originalCol = btn.BackgroundColor3
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = originalCol:Lerp(Color3.new(1,1,1), 0.2)}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = originalCol}):Play()
	end)
end

local function createActionBtn(name, posY, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.6, 0, 0, 40)
	btn.Position = UDim2.new(0.35, 0, 0, posY)
	btn.Text = name
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.Font = Enum.Font.GothamSemibold
	btn.Parent = hub
	applyStyle(btn, 6, true)
	addHover(btn)
	btn.MouseButton1Click:Connect(function()
		callback()
		btn.Text = "ATIVADO ✓"
		btn.TextColor3 = ACCENT_COLOR
	end)
end

