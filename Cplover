-- ================= FUNÇÕES CORE (O QUE VOCÊ PEDIU) =================

-- 1. ANTI-KNOCKBACK (Deleta forças aplicadas ao seu personagem)
player.CharacterAdded:Connect(function(char)
    char.DescendantAdded:Connect(function(v)
        if _G.AntiKBStatus then
            if v:IsA("BodyVelocity") or v:IsA("BodyGyro") or v:IsA("LinearVelocity") or v:IsA("VectorForce") then
                task.wait()
                v:Destroy()
            end
        end
    end)
end)

-- 2. HITBOX EXPANDER (Loop constante para evitar reset do jogo)
task.spawn(function()
    while task.wait(0.5) do
        if _G.HitboxStatus then
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = v.Character.HumanoidRootPart
                    hrp.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                    hrp.Transparency = 0.7
                    hrp.Color = Color3.fromRGB(255, 0, 0)
                    hrp.CanCollide = false
                end
            end
        end
    end
end)

-- 3. SPEED CFRAME & JUMP (Os que já funcionaram)
RunService.RenderStepped:Connect(function()
    if _G.SpeedStatus and player.Character and player.Character:FindFirstChild("Humanoid") then
        local hum = player.Character.Humanoid
        if hum.MoveDirection.Magnitude > 0 then
            player.Character:TranslateBy(hum.MoveDirection * _G.SpeedValue)
        end
    end
    
    if _G.JumpStatus and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            root.Velocity = Vector3.new(root.Velocity.X, 50, root.Velocity.Z)
        end
    end
end)

-- ================= SISTEMA DE BOTÕES ON/OFF =================

local function createOption(name, posY, flag)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.8, 0, 0, 45)
    btn.Position = UDim2.new(0.1, 0, 0, posY)
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.Parent = hub
    Instance.new("UICorner", btn)

    btn.MouseButton1Click:Connect(function()
        _G[flag] = not _G[flag]
        if _G[flag] then
            btn.Text = name .. ": ON"
            btn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        else
            btn.Text = name .. ": OFF"
            btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
            
            if flag == "HitboxStatus" then
                for _, v in pairs(Players:GetPlayers()) do
                    if v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(2,2,1)
                    end
                end
            end
        end
    end)
end

createOption("HITBOX EXPANDER", 70, "HitboxStatus")
createOption("ANTI-KNOCKBACK", 130, "AntiKBStatus")
createOption("CFRAME SPEED", 190, "SpeedStatus")
createOption("INFINITE JUMP", 250, "JumpStatus")

