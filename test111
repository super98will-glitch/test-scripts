-- ================= SISTEMA DE BYPASS (METATABLE) =================
-- Isso impede que o jogo detecte certas mudanças no seu personagem
local mt = getrawmetatable(game)
local old = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(t, k)
    if _G.Flags.AntiKB and t:IsA("Humanoid") and (k == "WalkSpeed" or k == "JumpPower") then
        return old(t, k)
    end
    return old(t, k)
end)
setreadonly(mt, true)

