-- ================= FUNÇÕES DE EXPLOIT (OPEN SOURCE) =================

-- 1. Anti-Knockback (Deleta forças de impacto do UBG)
task.spawn(function()
    RunService.Stepped:Connect(function()
        if _G.Flags.AntiKB and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(player.Character.HumanoidRootPart:GetChildren()) do
                if v:IsA("BodyVelocity") or v:IsA("LinearVelocity") or v:IsA("BodyGyro") then
                    v:Destroy()
                end
            end
        end
    end)
end)

-- 2. Hitbox Expander (Aumenta a área de dano dos inimigos)
task.spawn(function()
    while task.wait(0.5) do
        if _G.Flags.Hitbox then
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = v.Character.HumanoidRootPart
                    hrp.Size = Vector3.new(15, 15, 15)
                    hrp.Transparency = 0.6
                    hrp.Color = Color3.fromRGB(255, 0, 0)
                    hrp.CanCollide = false
                end
            end
        end
    end
end)

-- 3. CFrame Speed & Infinite Jump (Movimentação Bypass)
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        if _G.Flags.CFrameSpeed and char.Humanoid.MoveDirection.Magnitude > 0 then
            char:TranslateBy(char.Humanoid.MoveDirection * 1.3)
        end
        if _G.Flags.InfiniteJump and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            char.HumanoidRootPart.Velocity = Vector3.new(char.HumanoidRootPart.Velocity.X, 50, char.HumanoidRootPart.Velocity.Z)
        end
    end
end)

-- ================= CRIAÇÃO DOS BOTÕES =================

local function addExploit(name, flag)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.95, 0, 0, 45)
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn)

    btn.MouseButton1Click:Connect(function()
        _G.Flags[flag] = not _G.Flags[flag]
        btn.Text = _G.Flags[flag] and name .. ": ON" or name .. ": OFF"
        btn.BackgroundColor3 = _G.Flags[flag] and Color3.fromRGB(60, 120, 255) or Color3.fromRGB(30, 30, 40)
    end)
end

addExploit("HITBOX EXPANDER", "Hitbox")
addExploit("ANTI-KNOCKBACK", "AntiKB")
addExploit("CFRAME SPEED", "CFrameSpeed")
addExploit("INFINITE JUMP", "InfiniteJump")

-- Adicionando scripts externos famosos
local function addExternal(name, loadstr)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.95, 0, 0, 45)
    btn.Text = "CARREGAR " .. name
    btn.BackgroundColor3 = Color3.fromRGB(80, 40, 150)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function() loadstring(game:HttpGet(loadstr))() end)
end

addExternal("INFINITE YIELD", "https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source")
addExternal("DEX EXPLORER", "https://raw.githubusercontent.com/infYiff/reVamp/main/dex.lua")

