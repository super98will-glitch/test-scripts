-- ================= LÓGICA DE FUNCIONAMENTO =================

RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end

    -- Lógica CFrame Speed
    if _G.Flags.CFrameSpeed and char:FindFirstChild("Humanoid") then
        local hum = char.Humanoid
        if hum.MoveDirection.Magnitude > 0 then
            char:TranslateBy(hum.MoveDirection * _G.SpeedValue)
        end
    end

    -- Lógica Infinite Jump
    if _G.Flags.InfiniteJump and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then
            root.Velocity = Vector3.new(root.Velocity.X, 50, root.Velocity.Z)
        end
    end

    -- FullBright
    if _G.Flags.FullBright then
        Lighting.Ambient = Color3.new(1, 1, 1)
        Lighting.ClockTime = 12
    end
end)

-- Anti-Knockback e Hitbox
task.spawn(function()
    while task.wait(0.5) do
        if _G.Flags.Hitbox then
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    v.Character.HumanoidRootPart.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                    v.Character.HumanoidRootPart.Transparency = 0.7
                    v.Character.HumanoidRootPart.CanCollide = false
                end
            end
        end
    end
end)

