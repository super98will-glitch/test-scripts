-- ================= FUNÇÕES (BOTÕES ON/OFF) =================

local function createToggle(name, flag)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.95, 0, 0, 45)
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = scroll
    style(btn, 8)

    btn.MouseButton1Click:Connect(function()
        _G.Flags[flag] = not _G.Flags[flag]
        btn.Text = _G.Flags[flag] and name .. ": ON" or name .. ": OFF"
        btn.BackgroundColor3 = _G.Flags[flag] and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(35, 35, 45)
    end)
end

createToggle("CFRAME SPEED", "CFrameSpeed")
