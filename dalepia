-- ================= SISTEMA DE TOGGLES =================

local function createToggle(name, posY, flagName)
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.4, 0, 0, 40)
	label.Position = UDim2.new(0.05, 0, 0, posY)
	label.Text = name
	label.TextColor3 = Color3.new(1,1,1)
	label.Font = Enum.Font.GothamSemibold
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.BackgroundTransparency = 1
	label.Parent = hub

	local onBtn = Instance.new("TextButton")
	onBtn.Size = UDim2.new(0, 80, 0, 30)
	onBtn.Position = UDim2.new(0.5, 0, 0, posY + 5)
	onBtn.Text = "ON"
	onBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	onBtn.TextColor3 = Color3.new(1,1,1)
	onBtn.Parent = hub
	applyStyle(onBtn, 6)

	local offBtn = Instance.new("TextButton")
	offBtn.Size = UDim2.new(0, 80, 0, 30)
	offBtn.Position = UDim2.new(0.7, 0, 0, posY + 5)
	offBtn.Text = "OFF"
	offBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
	offBtn.TextColor3 = Color3.new(1,1,1)
	offBtn.Parent = hub
	applyStyle(offBtn, 6)

	onBtn.MouseButton1Click:Connect(function()
		Flags[flagName] = true
		onBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
		offBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	end)

	offBtn.MouseButton1Click:Connect(function()
		Flags[flagName] = false
		offBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
		onBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
	end)
end

createToggle("HITBOX EXPANDER", 60, "Hitbox")
createToggle("ANTI-KNOCKBACK", 110, "AntiKnockback")
createToggle("SPEED HACK", 160, "Speed")
createToggle("SUPER JUMP", 210, "Jump")

-- ================= LÓGICA DE JOGO (CORE) =================

RunService.Heartbeat:Connect(function()
	-- 1. Lógica do Hitbox (Ajustada para Ultimate Battlegrounds)
	if Flags.Hitbox then
		for _, v in pairs(Players:GetPlayers()) do
			if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
				v.Character.HumanoidRootPart.Size = Vector3.new(12, 12, 12) -- Tamanho ideal para UBG
				v.Character.HumanoidRootPart.Transparency = 0.7
				v.Character.HumanoidRootPart.Color = Color3.new(0, 1, 1)
				v.Character.HumanoidRootPart.CanCollide = false
			end
		end
	end

	-- 2. Anti-Knockback (Deleta forças de empurrão)
	if Flags.AntiKnockback then
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			for _, v in pairs(player.Character.HumanoidRootPart:GetChildren()) do
				if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") then
					v:Destroy()
				end
			end
		end
	end

	-- 3. Player Mods
	local char = player.Character
	if char and char:FindFirstChild("Humanoid") then
		if Flags.Speed then char.Humanoid.WalkSpeed = 45 end
		if Flags.Jump then char.Humanoid.JumpPower = 100 end
	end
end)

