local screenGui = Instance.new("ScreenGui", player.PlayerGui)
local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 250, 0, 300)
frame.Position = UDim2.new(0.5, -125, 0.5, -150)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Instance.new("UICorner", frame)

local function createBtn(name, pos, flag)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn)

    btn.MouseButton1Click:Connect(function()
        _G[flag] = not _G[flag]
        if _G[flag] then
            btn.Text = name .. ": ON"
            btn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
        else
            btn.Text = name .. ": OFF"
            btn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
            
            -- Reset Hitbox
            if flag == "HitboxStatus" then
                for _, v in pairs(Players:GetPlayers()) do
                    if v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        v.Character.HumanoidRootPart.Size = Vector3.new(2,2,1)
                    end
                end
            end
        end
    end)
end

createBtn("Hitbox", 20, "HitboxStatus")
createBtn("Anti-Knockback", 70, "AntiKBStatus")
createBtn("CFrame Speed", 120, "SpeedStatus")
createBtn("Infinite Jump", 170, "JumpStatus")

