-- ================= FUNÇÕES DE LOGICA =================

local function toggleHub(state)
	if state then
		blur.Enabled = true
		hub.Visible = true
		openButton.Visible = false
		hub:TweenSize(UDim2.new(0, 550, 0, 350), "Out", "Quad", 0.3, true)
	else
		blur.Enabled = false
		hub:TweenSize(UDim2.new(0, 0, 0, 0), "In", "Quad", 0.3, true, function()
			hub.Visible = false
			openButton.Visible = true
		end)
	end
end

-- Efeito Hover nos Botões
local function addHover(btn)
	local originalCol = btn.BackgroundColor3
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = originalCol:Lerp(Color3.new(1,1,1), 0.2)}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = originalCol}):Play()
	end)
end

-- Botões do HUB
local function createActionBtn(name, posY, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.8, 0, 0, 40)
	btn.Position = UDim2.new(0.1, 0, 0, posY)
	btn.Text = name
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Font = Enum.Font.GothamSemibold
	btn.Parent = hub
	btn.Position = UDim2.new(0.32, 0, 0, posY) -- Ajustado para o lado da sidebar
	applyStyle(btn, 6, true)
	addHover(btn)
	btn.MouseButton1Click:Connect(callback)
end

