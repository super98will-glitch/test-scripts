-- ================= LÓGICA DE FUNCIONAMENTO AGRESSIVO =================

RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    
    -- Lógica CFrame Speed (Bypass)
    if _G.Flags.CFrameSpeed and char:FindFirstChild("Humanoid") then
        if char.Humanoid.MoveDirection.Magnitude > 0 then
            char:TranslateBy(char.Humanoid.MoveDirection * 1.2)
        end
    end

    -- FullBright
    if _G.Flags.FullBright then
        Lighting.Ambient = Color3.new(1, 1, 1)
        Lighting.Brightness = 2
        Lighting.ClockTime = 12
    end
end)

-- Anti-Knockback Agressivo
player.CharacterAdded:Connect(function(char)
    char.DescendantAdded:Connect(function(v)
        if _G.Flags.AntiKB and (v:IsA("BodyVelocity") or v:IsA("LinearVelocity")) then
            task.wait()
            v:Destroy()
        end
    end)
end)

