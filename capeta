-- ================= FUNÇÕES OPEN SOURCE INTEGRADAS =================

local function createToggle(name, flag)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Text = name .. ": OFF"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn)

    btn.MouseButton1Click:Connect(function()
        _G.Flags[flag] = not _G.Flags[flag]
        btn.Text = _G.Flags[flag] and name .. ": ON" or name .. ": OFF"
        btn.BackgroundColor3 = _G.Flags[flag] and Color3.fromRGB(60, 120, 255) or Color3.fromRGB(40, 40, 50)
    end)
end

